# ─────────────────────────────────────────────────────────────────────────────
# SurveyeSSM v2 — Variabili d'ambiente
# Copia questo file in .env e compila i valori reali.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/socketsia_v2"

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-questa-chiave-in-produzione"
JWT_EXPIRES_IN="8h"

# ── Authentik OIDC ───────────────────────────────────────────────────────────
AUTHENTIK_CLIENT_ID=""
AUTHENTIK_CLIENT_SECRET=""
AUTHENTIK_BASE_URL="https://auth.tuodominio.it/"
AUTHENTIK_REDIRECT_URI="http://localhost:5173/api/auth/authentik/callback"

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp-relay.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
MAIL_FROM="sia@tuodominio.it"
MAIL_FROM_NAME="SurveyeSSM"
MAIL_TO="destinatario@tuodominio.it"

# ── API Abbonamenti ───────────────────────────────────────────────────────────
GO_API_URL="https://go.tuodominio.it/api/abbonamenti"
GO_API_TOKEN=""

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET="cambia-questa-chiave-in-produzione"

# ── Web Push (VAPID) — genera con: npx web-push generate-vapid-keys ──────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@tuodominio.it"

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN="http://localhost:5173"
TCP_PORT=23683
